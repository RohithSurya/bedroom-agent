sequenceDiagram
  actor User
  participant HA as Home Assistant / caller
  participant API as /agent/chat
  participant Router as NLRouter
  participant Analyzer as BedroomRoomAnalyzer
  participant Source as BedroomImageSource
  participant Model as LLM provider
  participant DB as SQLite

  User->>HA: "analyze bedroom"
  HA->>API: POST /agent/chat
  API->>Router: route(text, state)
  Router-->>API: intent=analyze_bedroom
  API->>Analyzer: analyze(query)
  Analyzer->>Source: get_bedroom_image()

  alt CAMERA_MODE=device
    Source->>Source: capture with fswebcam
  else CAMERA_MODE=ha_snapshot
    Source->>HA: GET /api/camera_proxy/<camera>
  else CAMERA_MODE=file
    Source->>Source: read fallback image
  end

  Source-->>Analyzer: image bytes + source metadata
  Analyzer->>Model: generate_raw(prompt, image)

  alt parse error or low-signal result
    Analyzer->>Model: generate_json(schema, image)
  end

  alt valid structured result
    Analyzer->>DB: set vision.latest_bedroom_analysis
    Analyzer->>DB: append bedroom_analysis_completed
    API-->>HA: mode=info + summary or query_answer
  else image or model failure
    Analyzer->>DB: append bedroom_analysis_failed
    API-->>HA: mode=info + fallback summary
  end

  HA-->>User: spoken response
