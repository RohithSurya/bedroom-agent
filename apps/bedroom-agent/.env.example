TIMEZONE=America/New_York
LOG_DIR=logs
AGENT_MODE=active
TOOL_BACKEND=http
HA_BASE_URL=http://localhost:8123
HA_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiI0YTUwODNhM2MzY2Y0NTgwYmEwZjY0YjQ2MmFmMzI3ZSIsImlhdCI6MTc3MTM2OTMwMSwiZXhwIjoyMDg2NzI5MzAxfQ.wgaGJm-lSj1VTHKs4Wj77g5y7HIOn-il5gZec-gVv1E


# Local on-device model endpoint (Ollama/TensorRT-LLM/etc.)
LLM_BASE_URL=http://localhost:8081/v1
LLM_MODEL=Ministral-3-3B-Instruct-2512-Q4_K_M.gguf
LLM_TIMEOUT_S=60
LLM_DECISION_ENABLED=true
LLM_DECISION_MIN_CONFIDENCE=0.55
LLM_DECISION_TIMEOUT_S=20
LLM_DECISION_USE_VISION=true
LLM_DECISION_MAX_EVENTS=8


# SQLite
SQLITE_PATH=./data/memory.sqlite


# MQTT (Zigbee2MQTT)
MQTT_HOST=host.docker.internal
MQTT_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=zigbee2mqtt

# Your Z2M topics (match YOUR Zigbee2MQTT device names).
# Z2M_DOOR_TOPIC accepts a comma-separated list when multiple door sensors
# should feed the same entry logic.
Z2M_DOOR_TOPIC=zigbee2mqtt/bedroom_door_sensor,zigbee2mqtt/bathroom_door_sensor
Z2M_PRESENCE_TOPIC=zigbee2mqtt/bedroom_mmwave_sensor

# Enter-room behavior
ENTRY_WINDOW_S=12
ENTRY_COOLDOWN_S=90
ENTRY_LIGHT_ENTITY_ID=light.bedroom_light
BEDROOM_FAN_ENTITY_ID=switch.bedroom_fan_plug
BEDROOM_AC_ENTITY_ID=climate.bedroom_ac
VACANCY_OFF_DELAY_S=120
TEMP_SENSOR_ENTITY_ID=sensor.temp_humidity_sensor_temperature
HUMIDITY_SENSOR_ENTITY_ID=sensor.temp_humidity_sensor_humidity
COMFORT_TRIGGER_TEMP_C=26
COMFORT_TRIGGER_HUMIDITY_PCT=65
COMFORT_TARGET_TEMP_C=24
SLEEP_TARGET_TEMP_C=24
FOCUS_MODE_ENABLE_FAN=true
FOCUS_MODE_ENABLE_CLIMATE=true
SLEEP_MODE_ENABLE_CLIMATE=true
COMFORT_USE_FAN_FALLBACK=true

# Vision
CAMERA_MODE=file
CAMERA_ENTITY_ID=
CAMERA_DEVICE=/dev/video0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_SKIP_FRAMES=30
VISION_FALLBACK_IMAGE_PATH=./data/demo-bedroom.jpg
VISION_DEBUG_SAVE_DIR=./data/debug
VISION_ANALYSIS_ENABLED=true
VISION_PROMPT_PROFILE=general
VISION_MAX_OUTPUT_TOKENS=160

# Quiet hours (optional)
QUIET_HOURS_START=23:30
QUIET_HOURS_END=08:00
