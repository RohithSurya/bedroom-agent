# Your Z2M topics (match YOUR Zigbee2MQTT device names)
Z2M_DOOR_TOPIC=zigbee2mqtt/bedroom_door_sensor
Z2M_PRESENCE_TOPIC=zigbee2mqtt/bedroom_mmwave_sensor

# Enter-room behavior
ENTRY_WINDOW_S=12
ENTRY_COOLDOWN_S=90
ENTRY_LIGHT_ENTITY_ID=light.bedroom_lamp
ENTRY_BRIGHTNESS_PCT=60
ENTRY_TRANSITION_S=0.4

# Quiet hours (optional)
QUIET_HOURS_START=23:30
QUIET_HOURS_END=08:00
QUIET_ENTRY_BRIGHTNESS_PCT=10


